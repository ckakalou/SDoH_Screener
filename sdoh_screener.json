            "id": "phq2_item1",
            "label": "Little interest or pleasure in doing things."
          },
          {
            "id": "phq2_item2",
            "label": "Feeling down, depressed, or hopeless."
          }
        ],
        "scoring": {
          "method": "sum",
          "positive_if": {
