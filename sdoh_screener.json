        "text": "Over the last 2 weeks, how often have you been bothered by the following problems? (PHQ-2)",
        "type": "matrix",
        "scale": [
          {
            "value": 0,
            "label": "Not at all"
          },
          {
            "value": 1,
            "label": "Several days"
          },
          {
            "value": 2,
            "label": "More than half the days"
          },
          {
            "value": 3,
            "label": "Nearly every day"
          }
        ],
        "rows": [
