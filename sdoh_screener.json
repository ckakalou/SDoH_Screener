                "default": 0
              }
            }
          ]
        },
        "output_key": "weekly_minutes_activity"
      },
      {
        "id": "c20_physical_activity_need",
        "description": "Physical activity need flag using age thresholds",
        "logic": {
          "any": [
            {
              "all": [
                {
                  "gte": [
                    {
                      "context": "age_years"
                    },
                    6
                  ]
                },
                {
                  "lte": [
                    {
                      "context": "age_years"
                    },
                    17
                  ]
                },
                {
                  "lt": [
                    {
                      "computed": "weekly_minutes_activity"
                    },
                    420
                  ]
                }
              ]
            },
            {
              "all": [
                {
                  "gte": [
                    {
                      "context": "age_years"
                    },
                    18
                  ]
                },
                {
                  "lt": [
                    {
                      "computed": "weekly_minutes_activity"
                    },
                    150
                  ]
                }
              ]
            }
          ]
        },
        "output_key": "physical_activity_need"
      }
