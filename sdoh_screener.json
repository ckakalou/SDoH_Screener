{
  "screener": {
    "title": "Social Determinants of Health (SDoH) Screener",
    "version": "1.0.0",
    "created": "2025-09-22",
    "language": "en",
    "notes": [
      "Derived from the user's provided 'SDoH proposed tool.docx'.",
      "Includes branching (skip logic) and scoring rules for depression (PHQ-2), intimate partner violence (HITS), and physical activity.",
      "For physical activity assessment, age is required; supply 'age_years' in patient context."
    ],
    "context_fields": [
      {
        "key": "age_years",
        "type": "integer",
        "required": false,
        "description": "Patient age in years, used for physical activity thresholds."
      },
      {
        "key": "spanish_version",
        "type": "boolean",
        "required": false,
        "default": false,
        "description": "If true, IPV (HITS) positive cutoff is 5.5 instead of 10.5."
      }
    ],
    "questions": [
